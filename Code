// Helper to generate clear, visible, vibrant colors
COLORREF GetRandomVibrantColor() {
    int r = rand() % 130 + 125; 
    int g = rand() % 130 + 125; 
    int b = rand() % 130 + 125; 
    return RGB(r, g, b);
}

void RandomizeTextTheme() {
    currentTextThemeColor = GetRandomVibrantColor();
    if (hTitleText) InvalidateRect(hTitleText, NULL, TRUE);
    if (hStatusText) InvalidateRect(hStatusText, NULL, TRUE);
    if (hScoreText) InvalidateRect(hScoreText, NULL, TRUE);
}

