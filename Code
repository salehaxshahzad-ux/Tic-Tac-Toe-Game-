    ShowWindow(hBtnPvC, SW_HIDE);
    ShowWindow(hBtnSubBack, SW_HIDE);
    ShowWindow(hStatusText, SW_HIDE);
    ShowWindow(hScoreText, SW_HIDE);
    ShowWindow(hBtnRestart, SW_HIDE);
    ShowWindow(hBtnBackToMenu, SW_HIDE);
