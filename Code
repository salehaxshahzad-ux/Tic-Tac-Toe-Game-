// ===== GLOBAL VARIABLES & GAME LOGIC =====
char board[3][3] = {{'1','2','3'},{'4','5','6'},{'7','8','9'}}; 
char turn = 'X'; 
bool vsComputer = false; 
int totalGames = 0, xWins = 0, oWins = 0, drawGames = 0; 
bool gameActive = false; 

// Track dynamic colors for elements
COLORREF cellColors[3][3];
COLORREF currentTextThemeColor = RGB(0, 240, 220); // Dynamic shifting label color

// ===== GUI WINDOW HANDLES =====
HWND hTitleText;
HWND hStatusText;
HWND hScoreText;

// Main Menu Controls
HWND hBtnStartGame, hBtnExitApp;

// Sub Menu Controls
HWND hBtnPvP, hBtnPvC, hBtnSubBack;

// Game Controls
HWND hGridButtons[3][3];
HWND hBtnRestart, hBtnBackToMenu;

// ===== THEME STYLING =====
HBRUSH hBackBrush = CreateSolidBrush(RGB(24, 20, 32)); // Deep Velvet Night Background
HFONT hFontLarge, hFontMedium;

// Forward declarations
void ResetGameGUI();
void ComputerMoveGUI();
bool CheckGameOverGUI();
void ShowMainPage();
void ShowSubPage();
void ShowGamePage();
